# 1. Базовый образ
FROM node:18-alpine

# 2. Установка рабочей директории
WORKDIR /app

# 3. Копирование файлов зависимостей и установка
COPY package*.json ./
RUN npm install

# 4. Копирование исходного кода приложения
COPY . .

# 5. Указание порта, который будет слушать контейнер
EXPOSE 3020

# 6. Команда для запуска приложения
CMD ["node", "server.js"]